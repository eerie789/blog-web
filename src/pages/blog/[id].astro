---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{post.data.title}</title>
		<meta name="description" content={post.data.description} />
	</head>
	<body class="max-w-3xl mx-auto p-4 md:p-8 bg-white text-gray-900 font-sans">
		<a href="/" class="text-blue-600 hover:underline mb-8 inline-block">&larr; Back to Home</a>
		
		<header class="mb-8">
			<h1 class="text-4xl font-bold mb-2">{post.data.title}</h1>
			<p class="text-gray-500">Published: {new Date(post.data.pubDate).toLocaleDateString()}</p>
		</header>

		<!-- Styling Markdown Content with Tailwind Typography -->
		<article class="prose prose-lg prose-blue max-w-none">
			<Content />
		</article>
	</body>
</html>
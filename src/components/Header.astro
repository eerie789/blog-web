---
// Header.astro - Komponen Header Global
---

<header class="bg-white shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center py-6">
      <div class="flex items-center">
        <a href="/" class="text-2xl font-bold text-gray-900">Blog Saya</a>
      </div>
      <nav class="hidden md:flex space-x-8">
        <a href="/" class="text-gray-700 hover:text-gray-900">Beranda</a>
        <a href="/about" class="text-gray-700 hover:text-gray-900">Tentang</a>
        <a href="/contact" class="text-gray-700 hover:text-gray-900">Kontak</a>
      </nav>
      <div class="md:hidden">
        <button class="text-gray-700 hover:text-gray-900 focus:outline-none">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>